---
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Philosophy from "../components/Philosophy.astro";
import DysportSection from "../components/DysportSection.astro";
import FillersSection from "../components/FillersSection.astro";
import MicroneedlingSection from "../components/MicroneedlingSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ResourcesSection from "../components/ResourcesSection.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

import "../styles/global.css";
import "../styles/nav.css";
import "../styles/hero.css";
import "../styles/sections.css";
import "../styles/fillers.css";
import "../styles/microneedling.css";

const bookingUrl = "https://rozehealth.janeapp.com/";
const portalUrl = "https://rozehealth.janeapp.com/";
const phoneDisplay = "647-865-8459";
const phoneHref = "+16478658459";
const email = "info@rozehealth.ca";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Roze Health is a physician-led medical aesthetics clinic in Thornhill offering Dysport®, personalized dermal filler treatments, and microneedling." />
    <link rel="canonical" href="https://www.roze-health.ca/" />
    <meta property="og:title" content="Roze Health | Physician-Led Medical Aesthetics" />
    <meta property="og:description" content="Personalized Dysport®, dermal filler, and microneedling treatments with a natural-results philosophy." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.roze-health.ca/" />
    <meta name="theme-color" content="#fbf7f3" />
    <link rel="icon" type="image/png" href="/images/roze-logo.png" />
    <title>Roze Health | Physician-Led Medical Aesthetics</title>
  </head>
  <body>
    <Navbar bookingUrl={bookingUrl} portalUrl={portalUrl} />
    <main>
      <Hero bookingUrl={bookingUrl} />
      <div id="treatments">
        <Philosophy />
        <DysportSection bookingUrl={bookingUrl} />
        <FillersSection bookingUrl={bookingUrl} />
        <MicroneedlingSection bookingUrl={bookingUrl} />
      </div>
      <AboutSection />
      <ResourcesSection />
      <FAQ />
      <CTA bookingUrl={bookingUrl} phoneDisplay={phoneDisplay} phoneHref={phoneHref} email={email} />
    </main>
    <Footer phoneDisplay={phoneDisplay} phoneHref={phoneHref} email={email} />

    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((element) => observer.observe(element));
    </script>
  </body>
</html>
